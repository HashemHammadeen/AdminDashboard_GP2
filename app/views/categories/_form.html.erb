<%= form_with(model: category, class: "space-y-5") do |form| %>
  <% if category.errors.any? %>
    <div class="bg-error/10 border border-error/20 rounded-lg p-4">
      <ul class="list-disc list-inside text-sm text-error/80 space-y-1"><% category.errors.each do |error| %><li><%= error.full_message %></li><% end %></ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, "Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :name, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors" %>
  </div>
  <div>
    <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_area :description, rows: 3, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors resize-none" %>
  </div>
  <div>
    <%= form.label :display_order, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.number_field :display_order, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors" %>
  </div>
  <div>
    <%= form.label :icon_url, "Icon URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :icon_url, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors" %>
  </div>
  <div class="flex items-center gap-3 pt-2">
    <%= form.submit class: "px-5 py-2.5 bg-primary hover:bg-primary-light text-white text-sm font-medium rounded-lg transition-colors cursor-pointer" %>
    <%= link_to "Cancel", categories_path, class: "px-5 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg transition-colors" %>
  </div>
<% end %>
