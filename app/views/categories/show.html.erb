<% content_for(:page_title) { @category.name } %>
<div class="mb-6">
  <%= link_to categories_path, class: "inline-flex items-center gap-1 text-sm text-secondary hover:text-primary transition-colors" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Back to Categories
  <% end %>
</div>
<div class="bg-white rounded-xl border border-gray-100 overflow-hidden">
  <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
    <h2 class="text-xl font-bold text-primary"><%= @category.name %></h2>
    <%= link_to edit_category_path(@category), class: "inline-flex items-center gap-2 px-3 py-2 bg-warning/10 text-warning hover:bg-warning/20 text-sm font-medium rounded-lg transition-colors" do %>Edit<% end %>
  </div>
  <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
    <div><p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Name</p><p class="text-sm text-primary font-medium"><%= @category.name %></p></div>
    <div><p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Display Order</p><p class="text-sm text-gray-700"><%= @category.display_order %></p></div>
    <div class="md:col-span-2"><p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Description</p><p class="text-sm text-gray-700"><%= @category.description || "—" %></p></div>
  </div>
</div>
