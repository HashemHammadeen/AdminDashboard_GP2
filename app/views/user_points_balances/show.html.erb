<% content_for(:page_title) { "User Points Balance Details" } %>

<div class="mb-6">
  <%= link_to user_points_balances_path, class: "inline-flex items-center gap-1 text-sm text-secondary hover:text-primary transition-colors" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Back to User Points Balances
  <% end %>
</div>

<div class="bg-white rounded-xl border border-gray-100 overflow-hidden shadow-sm max-w-3xl">
  <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
    <div class="flex items-center gap-3">
      <h2 class="text-xl font-bold text-primary">Points Balance</h2>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to edit_user_points_balance_path(@user_points_balance), class: "inline-flex items-center gap-2 px-3 py-2 bg-warning/10 text-warning hover:bg-warning/20 text-sm font-medium rounded-lg transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        Edit
      <% end %>
      <%= button_to @user_points_balance, method: :delete, form: { data: { turbo_confirm: 'Are you sure?' } }, class: "inline-flex items-center gap-2 px-3 py-2 bg-error/10 text-error hover:bg-error/20 text-sm font-medium rounded-lg transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        Delete
      <% end %>
    </div>
  </div>
  
  <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-8">
    <div>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">User Information</p>
      <div class="flex items-center gap-3">
        <div class="w-12 h-12 rounded-full bg-secondary/10 flex items-center justify-center text-secondary font-bold text-lg flex-shrink-0">
          <%= @user_points_balance.user ? @user_points_balance.user.first_name[0].upcase : "?" %>
        </div>
        <div>
          <p class="text-base font-medium text-primary"><%= @user_points_balance.user ? [@user_points_balance.user.first_name, @user_points_balance.user.last_name].join(" ") : "Unknown User" %></p>
          <p class="text-sm text-gray-500"><%= @user_points_balance.user&.email %></p>
        </div>
      </div>
    </div>
    
    <div class="grid grid-cols-2 gap-4">
      <div class="bg-blue-50 rounded-xl p-4 border border-blue-100">
        <p class="text-xs font-semibold text-blue-500 uppercase tracking-wider mb-1">Total Points</p>
        <p class="text-2xl font-bold text-blue-700"><%= number_with_delimiter(@user_points_balance.total_points) %></p>
      </div>
      
      <div class="bg-purple-50 rounded-xl p-4 border border-purple-100">
        <p class="text-xs font-semibold text-purple-500 uppercase tracking-wider mb-1">Lifetime Points</p>
        <p class="text-2xl font-bold text-purple-700"><%= number_with_delimiter(@user_points_balance.lifetime_points) %></p>
      </div>
    </div>

    <div>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Last Updated</p>
      <p class="text-sm text-gray-700"><%= @user_points_balance.updated_at.strftime("%B %d, %Y at %H:%M") %></p>
    </div>
  </div>
</div>
