<% content_for(:page_title) { "Update Receipt" } %>
<div class="mb-6">
  <%= link_to receipt_path(@receipt), class: "inline-flex items-center gap-1 text-sm text-secondary hover:text-primary transition-colors" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Back to Receipt
  <% end %>
</div>

<div class="bg-white rounded-xl border border-gray-100 overflow-hidden max-w-2xl">
  <div class="px-6 py-5 border-b border-gray-100">
    <h2 class="text-xl font-bold text-primary">Update Receipt Status</h2>
  </div>
  <div class="p-6">
    <%= form_with(model: @receipt, class: "space-y-5") do |form| %>
      <div>
        <%= form.label :status, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.select :status, [["Pending", "pending"], ["Approved", "approved"], ["Rejected", "rejected"]], {}, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors" %>
      </div>
      <div class="flex items-center gap-3 pt-2">
        <%= form.submit "Update Status", class: "px-5 py-2.5 bg-primary hover:bg-primary-light text-white text-sm font-medium rounded-lg transition-colors cursor-pointer" %>
        <%= link_to "Cancel", receipt_path(@receipt), class: "px-5 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
