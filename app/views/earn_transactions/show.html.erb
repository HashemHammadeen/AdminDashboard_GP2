<% content_for(:page_title) { "Transaction Details" } %>
<div class="mb-6">
  <%= link_to earn_transactions_path, class: "inline-flex items-center gap-1 text-sm text-secondary hover:text-primary transition-colors" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Back to Transactions
  <% end %>
</div>

<div class="bg-white rounded-xl border border-gray-100 overflow-hidden">
  <div class="px-6 py-5 border-b border-gray-100">
    <h2 class="text-xl font-bold text-primary">Earn Transaction</h2>
  </div>
  <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Transaction Ref</p>
      <p class="text-sm font-medium text-primary"><%= @earn_transaction.transaction_ref || @earn_transaction.id.first(8) %></p>
    </div>
    <div>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Purchase Amount</p>
      <p class="text-2xl font-bold text-primary"><%= number_to_currency(@earn_transaction.purchase_amount) %></p>
    </div>
    <div>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Points Earned</p>
      <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold bg-success/10 text-success">+<%= @earn_transaction.points_earned %></span>
    </div>
    <div>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Date</p>
      <p class="text-sm text-gray-700"><%= @earn_transaction.created_at.strftime("%B %d, %Y at %H:%M") %></p>
    </div>
  </div>
</div>
