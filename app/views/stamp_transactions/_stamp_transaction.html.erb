<div id="<%= dom_id stamp_transaction %>">
  <div>
    <strong>User:</strong>
    <%= stamp_transaction.user_id %>
  </div>

  <div>
    <strong>Shop:</strong>
    <%= stamp_transaction.shop_id %>
  </div>

  <div>
    <strong>Stamp Program:</strong>
    <%= stamp_transaction.stamp_program_id %>
  </div>

  <div>
    <strong>Type:</strong>
    <%= stamp_transaction.type %>
  </div>

  <div>
    <strong>Stamps count:</strong>
    <%= stamp_transaction.stamps_count %>
  </div>

  <div>
    <strong>Redemption Ref:</strong>
    <%= stamp_transaction.redemption_ref %>
  </div>

</div>
