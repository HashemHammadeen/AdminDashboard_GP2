<% content_for(:page_title) { "QR Code Details" } %>

<div class="max-w-3xl bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
  <div class="px-6 py-5 border-b border-gray-100 flex items-center justify-between bg-gray-50/50">
    <div>
      <h3 class="text-lg font-medium leading-6 text-primary">QR Code Information</h3>
      <p class="mt-1 text-sm text-gray-500">ID: QR-<%= @qr.id.to_s.split('-').first.upcase %></p>
    </div>
    <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium bg-success/10 text-success border border-success/20">
      Active
    </span>
  </div>

  <div class="px-6 py-5 border-t border-gray-100 flex flex-col items-center justify-center p-10 bg-gray-50">
    <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-200">
      <% if @qr.qr_code_data.present? %>
        <% qr_data = @qr.qr_code_data.is_a?(String) ? @qr.qr_code_data : JSON.generate(@qr.qr_code_data) %>
        <% qrcode = RQRCode::QRCode.new(qr_data) %>
        <div class="p-4 bg-white rounded-lg">
          <%= raw qrcode.as_svg(
            color: "000",
            shape_rendering: "crispEdges",
            module_size: 6,
            standalone: true,
            use_path: true
          ) %>
        </div>
      <% else %>
        <div class="w-64 h-64 border-4 border-dashed border-gray-300 rounded-lg flex items-center justify-center text-gray-400 font-mono text-sm break-all text-center p-4">
          No QR data found.
        </div>
      <% end %>
    </div>
    <p class="mt-4 text-sm font-medium text-gray-700">Scan to process transaction</p>
  </div>
  
  <div class="bg-gray-50 px-6 py-4 border-t border-gray-100 flex items-center justify-between">
    <%= button_to "Delete QR Code", @qr, method: :delete, data: { turbo_confirm: "Are you sure you want to delete this QR code?" }, class: "text-sm text-red-600 hover:text-red-800 font-medium transition-colors" %>
    <%= link_to "Back to QR Codes", qrs_path, class: "text-sm font-medium text-secondary hover:text-primary transition-colors" %>
  </div>
</div>
