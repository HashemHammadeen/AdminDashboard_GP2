<%= form_with(model: qr, class: "space-y-6") do |form| %>
  <% if qr.errors.any? %>
    <div class="bg-red-50 text-red-600 p-4 rounded-xl border border-red-100 mb-6">
      <h2 class="font-medium text-red-800"><%= pluralize(qr.errors.count, "error") %> prohibited this QR code from being saved:</h2>
      <ul class="list-disc pl-5 mt-2 text-sm">
        <% qr.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div data-controller="select-filter" class="space-y-2">
    <%= form.label :user_id, "Assign to User", class: "block text-sm font-medium text-gray-700 mb-1" %>
    
    <div class="relative">
      <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
        <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
      </div>
      <input type="text" data-select-filter-target="input" data-action="input->select-filter#filter" placeholder="Search users by name or email..." class="block w-full pl-10 pr-3 py-2 border border-gray-200 rounded-lg text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors bg-white">
    </div>

    <%= form.collection_select :user_id, @users || User.all, :id, ->(u) { "#{u.firstname} #{u.lastname} (#{u.email})" }, { prompt: "Choose a user..." }, class: "w-full px-3 py-2 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors bg-white", data: { select_filter_target: "select" }, size: 5 %>
  </div>

  <% if current_mall_admin %>
    <div>
      <%= form.label :shop_id, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.collection_select :shop_id, current_mall.shops, :id, :name, { prompt: "Select a shop" }, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-primary focus:ring-primary sm:text-sm" %>
    </div>
  <% else %>
    <%= form.hidden_field :shop_id, value: current_shop.id %>
  <% end %>

  <div class="flex items-center justify-end gap-3 pt-4 border-t border-gray-100">
    <%= link_to "Cancel", qrs_path, class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-colors" %>
    <%= form.submit "Generate QR Code", class: "px-4 py-2 text-sm font-medium text-white bg-primary border border-transparent rounded-lg hover:bg-primary-light focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary shadow-sm transition-colors cursor-pointer" %>
  </div>
<% end %>
