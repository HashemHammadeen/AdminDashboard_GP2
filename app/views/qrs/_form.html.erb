<%= form_with(model: qr) do |form| %>
  <% if qr.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(qr.errors.count, "error") %> prohibited this qr from being saved:</h2>

      <ul>
        <% qr.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :user_id, style: "display: block" %>
    <%= form.text_field :user_id %>
  </div>

  <div>
    <%= form.label :shop_id, style: "display: block" %>
    <%= form.text_field :shop_id %>
  </div>

  <div>
    <%= form.label :qr_code_data, style: "display: block" %>
    <%= form.textarea :qr_code_data %>
  </div>

  <div>
    <%= form.label :expires_at, style: "display: block" %>
    <%= form.datetime_field :expires_at %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
