<% content_for(:page_title) { "Redeem Transaction" } %>
<div class="mb-6"><%= link_to redeem_transactions_path, class: "inline-flex items-center gap-1 text-sm text-secondary hover:text-primary transition-colors" do %><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>Back<% end %></div>
<div class="bg-white rounded-xl border border-gray-100 overflow-hidden">
  <div class="px-6 py-5 border-b border-gray-100"><h2 class="text-xl font-bold text-primary">Redeem Transaction</h2></div>
  <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
    <div><p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Verification Code</p><p class="text-lg font-mono font-bold text-primary"><%= @redeem_transaction.verification_code %></p></div>
    <div><p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Points Used</p><span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold bg-error/10 text-error">-<%= @redeem_transaction.points_used %></span></div>
    <div><p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Discount Value</p><p class="text-2xl font-bold text-primary"><%= number_to_currency(@redeem_transaction.discount_value) %></p></div>
    <div><p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Status</p>
      <% if @redeem_transaction.verified? %><span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-success/10 text-success">Verified</span>
      <% elsif @redeem_transaction.pending? %><span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-warning/10 text-warning">Pending</span>
      <% else %><span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600"><%= @redeem_transaction.status %></span>
      <% end %>
    </div>
    <div><p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Date</p><p class="text-sm text-gray-700"><%= @redeem_transaction.created_at.strftime("%B %d, %Y at %H:%M") %></p></div>
    <div><p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Completed At</p><p class="text-sm text-gray-700"><%= @redeem_transaction.completed_at&.strftime("%B %d, %Y at %H:%M") || "—" %></p></div>
  </div>
</div>
