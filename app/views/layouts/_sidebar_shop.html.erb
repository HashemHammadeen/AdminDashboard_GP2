<%= link_to shop_dashboards_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors #{current_page?(shop_dashboards_path) ? 'bg-white/15 text-white' : 'text-ternary hover:bg-white/10 hover:text-white'}" do %>
