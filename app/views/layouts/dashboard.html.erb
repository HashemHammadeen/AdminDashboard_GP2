<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "Mall Admin Dashboard" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Mall Management System">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full bg-gray-50 font-sans" data-controller="sidebar">
    <!-- Mobile sidebar overlay -->
    <div data-sidebar-target="overlay" class="hidden fixed inset-0 bg-black/50 z-40 lg:hidden" data-action="click->sidebar#close"></div>

    <div class="flex h-full">
      <!-- Sidebar -->
      <aside data-sidebar-target="sidebar" class="fixed inset-y-0 left-0 z-50 w-64 bg-primary transform -translate-x-full lg:translate-x-0 lg:static lg:inset-auto transition-transform duration-300 ease-in-out flex flex-col">
        <!-- Logo / Brand -->
        <div class="flex items-center gap-3 px-6 py-5 border-b border-white/10">
          <div class="w-9 h-9 rounded-lg bg-white/20 flex items-center justify-center">
            <svg class="w-5 h-5 text-quaternary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
          </div>
          <div>
            <h1 class="text-white font-bold text-sm tracking-wide">
              <%= mall_admin_signed_in? ? "Mall Manager" : "Shop Manager" %>
            </h1>
            <p class="text-ternary text-xs">
              <%= mall_admin_signed_in? ? "Admin Dashboard" : "Shop Dashboard" %>
            </p>
          </div>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 overflow-y-auto px-3 py-4 space-y-1">
          <% if mall_admin_signed_in? %>
            <%= render "layouts/sidebar_mall" %>
          <% elsif shop_admin_signed_in? %>
            <%= render "layouts/sidebar_shop" %>
          <% end %>
        </nav>

        <!-- Admin Profile & Sign Out -->
        <div class="border-t border-white/10 px-4 py-4">
          <% admin = current_mall_admin || current_shop_admin %>
          <div class="flex items-center gap-3 mb-3">
            <div class="w-8 h-8 rounded-full bg-secondary flex items-center justify-center text-white text-xs font-bold">
              <%= admin&.name&.first&.upcase %>
            </div>
            <div class="min-w-0 flex-1">
              <p class="text-white text-sm font-medium truncate"><%= admin&.name %></p>
              <p class="text-ternary text-xs truncate"><%= admin&.email %></p>
            </div>
          </div>
          <% if mall_admin_signed_in? %>
            <%= link_to mall_admin_logout_path, method: :delete, data: { turbo_method: :delete }, class: "flex items-center gap-2 text-ternary hover:text-white text-sm transition-colors w-full" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
              Sign Out
            <% end %>
          <% elsif shop_admin_signed_in? %>
            <%= link_to shop_admin_logout_path, method: :delete, data: { turbo_method: :delete }, class: "flex items-center gap-2 text-ternary hover:text-white text-sm transition-colors w-full" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
              Sign Out
            <% end %>
          <% end %>
        </div>
      </aside>

      <!-- Main Content Area -->
      <div class="flex-1 flex flex-col min-h-screen lg:ml-0">
        <!-- Top Nav Bar -->
        <header class="bg-white border-b border-gray-200 sticky top-0 z-30">
          <div class="flex items-center justify-between px-4 sm:px-6 py-3">
            <!-- Mobile menu button -->
            <button data-action="click->sidebar#toggle" class="lg:hidden p-2 rounded-lg text-gray-500 hover:bg-gray-100 transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
            </button>

            <!-- Page title -->
            <div class="flex-1 ml-3 lg:ml-0">
              <h2 class="text-lg font-semibold text-primary"><%= content_for(:page_title) || "Dashboard" %></h2>
              <% if content_for?(:page_subtitle) %>
                <p class="text-sm text-gray-500"><%= yield :page_subtitle %></p>
              <% end %>
            </div>

            <!-- Right side -->
            <div class="flex items-center gap-3">
              <% if mall_admin_signed_in? && current_mall_admin.mall %>
                <span class="hidden sm:inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-primary/5 text-primary text-xs font-medium">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                  <%= current_mall_admin.mall.name %>
                </span>
              <% elsif shop_admin_signed_in? && current_shop_admin.shop %>
                <span class="hidden sm:inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-secondary/10 text-secondary text-xs font-medium">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
                  <%= current_shop_admin.shop.name %>
                </span>
              <% end %>
            </div>
          </div>
        </header>

        <!-- Flash Messages -->
        <% if notice.present? || alert.present? %>
          <div class="px-4 sm:px-6 pt-4">
            <%= render "shared/flash" %>
          </div>
        <% end %>

        <!-- Page Content -->
        <main class="flex-1 overflow-y-auto p-4 sm:p-6">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
