<%= form_with(model: stamp, class: "space-y-5") do |form| %>
  <% if stamp.errors.any? %>
    <div class="bg-error/10 border border-error/20 rounded-lg p-4">
      <ul class="list-disc list-inside text-sm text-error/80 space-y-1"><% stamp.errors.each do |error| %><li><%= error.full_message %></li><% end %></ul>
    </div>
  <% end %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    <div>
      <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :name, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors" %>
    </div>
    <div>
      <%= form.label :stamps_required, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.number_field :stamps_required, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors" %>
    </div>
    <div>
      <%= form.label :reward_type, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :reward_type, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors" %>
    </div>
    <div>
      <%= form.label :start_date, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.datetime_local_field :start_date, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors" %>
    </div>
    <div>
      <%= form.label :end_date, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.datetime_local_field :end_date, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors" %>
    </div>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    <div>
      <%= form.label :image_url, "Image URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :image_url, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors" %>
    </div>
    <div data-controller="flutter-icon-picker" class="relative">
      <%= form.label :stamp_icon_url, "Stamp Icon", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.hidden_field :stamp_icon_url, data: { flutter_icon_picker_target: "hidden" } %>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
        </div>
        <input type="text" data-flutter-icon-picker-target="search" data-action="input->flutter-icon-picker#search keydown->flutter-icon-picker#keydown" placeholder="Search icons (e.g. heart, star, circle)..." autocomplete="off" class="w-full pl-10 pr-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors">
      </div>
      <div data-flutter-icon-picker-target="dropdown" class="hidden absolute z-50 mt-1 w-full bg-white border border-gray-200 rounded-lg shadow-lg flutter-icon-picker-dropdown"></div>
      <div data-flutter-icon-picker-target="preview" class="<%= stamp.stamp_icon_url.present? ? '' : 'hidden' %> mt-3 flex items-center gap-3 p-3 bg-gray-50 rounded-lg border border-gray-100 flutter-icon-preview">
        <span class="material-icons"><%= stamp.stamp_icon_url %></span>
        <div>
          <p class="text-xs font-medium text-gray-500">Selected Icon</p>
          <p data-flutter-icon-picker-target="previewName" class="text-sm font-mono text-primary font-medium"><%= stamp.stamp_icon_url %></p>
        </div>
      </div>
    </div>
  </div>
  <div>
    <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_area :description, rows: 3, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors resize-none" %>
  </div>
  <div class="flex items-center gap-3">
    <%= form.label :is_active, class: "flex items-center gap-2 cursor-pointer" do %>
      <%= form.check_box :is_active, class: "w-4 h-4 rounded border-gray-300 text-secondary focus:ring-secondary" %>
      <span class="text-sm font-medium text-gray-700">Active</span>
    <% end %>
  </div>
  <div class="flex items-center gap-3 pt-2">
    <%= form.submit class: "px-5 py-2.5 bg-primary hover:bg-primary-light text-white text-sm font-medium rounded-lg transition-colors cursor-pointer" %>
    <%= link_to "Cancel", stamps_path, class: "px-5 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg transition-colors" %>
  </div>
<% end %>
