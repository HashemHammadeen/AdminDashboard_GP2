<%= form_with(model: tier, class: "space-y-5") do |form| %>
  <% if tier.errors.any? %>
    <div class="bg-error/10 border border-error/20 rounded-lg p-4">
      <ul class="list-disc list-inside text-sm text-error/80 space-y-1"><% tier.errors.each do |error| %><li><%= error.full_message %></li><% end %></ul>
    </div>
  <% end %>
  <div>
    <%= form.label :tier_name, "Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :tier_name, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors" %>
  </div>
  <div>
    <%= form.label :points_required, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.number_field :points_required, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors" %>
  </div>
  <div>
    <%= form.label :color_hex, "Color (hex)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.color_field :color_hex, class: "w-12 h-10 p-1 border border-gray-200 rounded-lg cursor-pointer" %>
  </div>
  <div>
    <%= form.label :icon_url, "Icon URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :icon_url, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors" %>
  </div>
  <div class="flex items-center gap-3 pt-2">
    <%= form.submit class: "px-5 py-2.5 bg-primary hover:bg-primary-light text-white text-sm font-medium rounded-lg transition-colors cursor-pointer" %>
    <%= link_to "Cancel", tiers_path, class: "px-5 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg transition-colors" %>
  </div>
<% end %>
