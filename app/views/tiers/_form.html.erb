<%= form_with(model: tier) do |form| %>
  <% if tier.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(tier.errors.count, "error") %> prohibited this tier from being saved:</h2>

      <ul>
        <% tier.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :tier_name, style: "display: block" %>
    <%= form.text_field :tier_name %>
  </div>

  <div>
    <%= form.label :points_required, style: "display: block" %>
    <%= form.number_field :points_required %>
  </div>

  <div>
    <%= form.label :benefits, style: "display: block" %>
    <%= form.text_field :benefits %>
  </div>

  <div>
    <%= form.label :icon_url, style: "display: block" %>
    <%= form.text_field :icon_url %>
  </div>

  <div>
    <%= form.label :color_hex, style: "display: block" %>
    <%= form.text_field :color_hex %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
