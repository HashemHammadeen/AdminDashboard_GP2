<% content_for(:page_title) { @tier.tier_name } %>
<div class="mb-6"><%= link_to tiers_path, class: "inline-flex items-center gap-1 text-sm text-secondary hover:text-primary transition-colors" do %><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>Back to Tiers<% end %></div>
<div class="bg-white rounded-xl border border-gray-100 overflow-hidden">
  <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
    <h2 class="text-xl font-bold text-primary"><%= @tier.tier_name %></h2>
    <%= link_to edit_tier_path(@tier), class: "inline-flex items-center gap-2 px-3 py-2 bg-warning/10 text-warning hover:bg-warning/20 text-sm font-medium rounded-lg transition-colors" do %>Edit<% end %>
  </div>
  <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
    <div><p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Tier Name</p><p class="text-sm text-primary font-medium"><%= @tier.tier_name %></p></div>
    <div><p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Points Required</p><p class="text-sm text-gray-700"><%= number_with_delimiter(@tier.points_required) %> pts</p></div>
    <div><p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Color</p>
      <div class="flex items-center gap-2"><% if @tier.color_hex.present? %><div class="w-4 h-4 rounded-full border border-gray-200" style="background-color: <%= @tier.color_hex %>"></div><% end %><span class="text-sm font-mono text-gray-700"><%= @tier.color_hex || "—" %></span></div>
    </div>
    <div><p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Benefits</p><p class="text-sm text-gray-700"><%= @tier.benefits || "—" %></p></div>
  </div>
</div>
