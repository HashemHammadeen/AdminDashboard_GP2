<% content_for(:page_title) { "Shop Dashboard" } %>
<% content_for(:page_subtitle) { @shop.name } %>

<!-- Stat Cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <%= render "shared/stat_card", title: "Points Earned", value: number_with_delimiter(@total_points_earned || 0), icon: "currency", color: "success" %>
  <%= render "shared/stat_card", title: "Total Revenue", value: number_to_currency(@total_revenue || 0), icon: "chart", color: "primary" %>
  <%= render "shared/stat_card", title: "Earn Transactions", value: @earn_transactions_count, icon: "currency", color: "info" %>
  <%= render "shared/stat_card", title: "Redeem Transactions", value: @redeem_transactions_count, icon: "gift", color: "secondary" %>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <%= render "shared/stat_card", title: "Active Offers", value: @active_offers, icon: "gift", color: "success" %>
  <%= render "shared/stat_card", title: "Offer Redemptions", value: @offer_redemptions_count, icon: "star", color: "info" %>
  <%= render "shared/stat_card", title: "Pending Receipts", value: @pending_receipts, icon: "receipt", color: "warning" %>
  <%= render "shared/stat_card", title: "Stamp Cards", value: @stamp_cards_count, subtitle: "#{@active_stamp_cards} active", icon: "star", color: "secondary" %>
</div>

<!-- Shop Profile Card -->
<div class="bg-white rounded-xl border border-gray-100 p-6 mb-8">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-lg font-semibold text-primary">Shop Profile</h3>
    <%= link_to edit_shop_path(@shop), class: "text-sm text-secondary hover:text-primary font-medium transition-colors" do %>
      Edit Profile →
    <% end %>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div>
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Shop Name</p>
      <p class="text-sm font-semibold text-primary"><%= @shop.name %></p>
    </div>
    <div>
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Category</p>
      <p class="text-sm text-gray-700"><%= @shop.category&.name || "—" %></p>
    </div>
    <div>
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Status</p>
      <% if @shop.is_active %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-success/10 text-success">Active</span>
      <% else %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-error/10 text-error">Inactive</span>
      <% end %>
    </div>
    <div>
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Mall</p>
      <p class="text-sm text-gray-700"><%= @shop.mall&.mall_name %></p>
    </div>
    <div>
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Website</p>
      <p class="text-sm text-gray-700"><%= @shop.website_url || "—" %></p>
    </div>
    <div>
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Bio</p>
      <p class="text-sm text-gray-700 line-clamp-2"><%= @shop.bio || "—" %></p>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <!-- Recent Earn Transactions -->
  <div class="bg-white rounded-xl border border-gray-100 overflow-hidden">
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
      <h3 class="text-lg font-semibold text-primary">Recent Earn Transactions</h3>
      <%= link_to "View All →", earn_transactions_path, class: "text-sm text-secondary hover:text-primary font-medium transition-colors" %>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="bg-gray-50">
            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Ref</th>
            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Amount</th>
            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Points</th>
            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Date</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @recent_earn_transactions.each_with_index do |txn, idx| %>
            <tr class="<%= idx.even? ? 'bg-white' : 'bg-quaternary/30' %> hover:bg-ternary/10 transition-colors">
              <td class="px-6 py-3 text-sm font-medium text-primary">
                <%= link_to (txn.transaction_ref || txn.id.first(8)), earn_transaction_path(txn), class: "hover:text-secondary transition-colors" %>
              </td>
              <td class="px-6 py-3 text-sm text-gray-600"><%= number_to_currency(txn.purchase_amount) %></td>
              <td class="px-6 py-3 text-sm font-semibold text-success">+<%= txn.points_earned %></td>
              <td class="px-6 py-3 text-sm text-gray-500"><%= txn.created_at.strftime("%b %d, %H:%M") %></td>
            </tr>
          <% end %>
          <% if @recent_earn_transactions.empty? %>
            <tr><td colspan="4" class="px-6 py-8 text-center text-gray-400 text-sm">No transactions yet</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Recent Receipts -->
  <div class="bg-white rounded-xl border border-gray-100 overflow-hidden">
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
      <h3 class="text-lg font-semibold text-primary">Recent Receipts</h3>
      <%= link_to "View All →", receipts_path, class: "text-sm text-secondary hover:text-primary font-medium transition-colors" %>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="bg-gray-50">
            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">ID</th>
            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Amount</th>
            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Status</th>
            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Date</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @recent_receipts.each_with_index do |receipt, idx| %>
            <tr class="<%= idx.even? ? 'bg-white' : 'bg-quaternary/30' %> hover:bg-ternary/10 transition-colors">
              <td class="px-6 py-3 text-sm font-medium text-primary">
                <%= link_to receipt.id.first(8), receipt_path(receipt), class: "hover:text-secondary transition-colors" %>
              </td>
              <td class="px-6 py-3 text-sm text-gray-600"><%= number_to_currency(receipt.amount) %></td>
              <td class="px-6 py-3">
                <% case receipt.status %>
                <% when "approved" %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-success/10 text-success">Approved</span>
                <% when "pending" %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-warning/10 text-warning">Pending</span>
                <% when "rejected" %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-error/10 text-error">Rejected</span>
                <% else %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600"><%= receipt.status %></span>
                <% end %>
              </td>
              <td class="px-6 py-3 text-sm text-gray-500"><%= receipt.created_at.strftime("%b %d, %H:%M") %></td>
            </tr>
          <% end %>
          <% if @recent_receipts.empty? %>
            <tr><td colspan="4" class="px-6 py-8 text-center text-gray-400 text-sm">No receipts yet</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
