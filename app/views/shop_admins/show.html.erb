<% content_for(:page_title) { "Shop Admin Details" } %>

<div class="mb-6">
  <%= link_to shop_admins_path, class: "inline-flex items-center gap-1 text-sm text-secondary hover:text-primary transition-colors" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Back to Shop Admins
  <% end %>
</div>

<div class="bg-white rounded-xl border border-gray-100 overflow-hidden shadow-sm max-w-3xl">
  <div class="px-6 py-5 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
    <div class="flex items-center gap-4">
      <div class="h-12 w-12 rounded-full bg-secondary/10 flex items-center justify-center text-secondary font-bold text-lg">
        <%= @shop_admin.name.first.upcase %>
      </div>
      <div>
        <div class="flex items-center gap-2">
          <h2 class="text-xl font-bold text-primary"><%= @shop_admin.name %></h2>
          <% if @shop_admin.is_active %>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-success/10 text-success">Active</span>
          <% else %>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-500">Inactive</span>
          <% end %>
        </div>
        <p class="text-sm text-gray-500"><%= @shop_admin.email %></p>
      </div>
    </div>
    <div class="flex gap-2">
      <%= link_to edit_shop_admin_path(@shop_admin), class: "inline-flex items-center gap-2 px-3 py-2 bg-secondary/10 text-secondary hover:bg-secondary hover:text-white text-sm font-medium rounded-lg transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
        Edit
      <% end %>
    </div>
  </div>
  
  <div class="p-6">
    <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-4 gap-y-6">
      <div>
        <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Shop</dt>
        <dd class="text-sm font-medium text-gray-900"><%= @shop_admin.shop&.name || @shop_admin.shop_id %></dd>
      </div>
      <div>
        <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Phone Number</dt>
        <dd class="text-sm font-medium text-gray-900"><%= @shop_admin.phone %></dd>
      </div>
      <div>
        <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Role</dt>
        <dd class="text-sm font-medium text-gray-900"><%= @shop_admin.role.titleize %></dd>
      </div>
      <div>
        <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Created At</dt>
        <dd class="text-sm text-gray-700"><%= @shop_admin.created_at.strftime("%B %d, %Y") %></dd>
      </div>
    </dl>
  </div>
</div>
