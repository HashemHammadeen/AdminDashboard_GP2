<%= form_with(model: shop_admin) do |form| %>
  <% if shop_admin.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(shop_admin.errors.count, "error") %> prohibited this shop_admin from being saved:</h2>

      <ul>
        <% shop_admin.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :shop_id, style: "display: block" %>
    <%= form.text_field :shop_id %>
  </div>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :email, style: "display: block" %>
    <%= form.text_field :email %>
  </div>

  <div>
