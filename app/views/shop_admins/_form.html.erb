<%= form_with(model: shop_admin, url: shop_admin.persisted? ? shop_admin_path(shop_admin) : shop_admins_path, class: "space-y-6", multipart: true) do |form| %>
  <% if shop_admin.errors.any? %>
    <div class="bg-red-50 text-red-600 p-4 rounded-xl border border-red-100 mb-6">
      <h2 class="font-medium text-red-800"><%= pluralize(shop_admin.errors.count, "error") %> prohibited this admin from being saved:</h2>
      <ul class="list-disc pl-5 mt-2 text-sm">
        <% shop_admin.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= form.label :name, "Admin Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :name, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-primary focus:ring-primary sm:text-sm" %>
    </div>

    <div>
      <%= form.label :phone, "Phone Number", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :phone, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-primary focus:ring-primary sm:text-sm" %>
    </div>
  </div>

  <div>
    <%= form.label :email, "Email Address", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.email_field :email, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-primary focus:ring-primary sm:text-sm" %>
  </div>

  <% if current_mall_admin && controller_name == 'shop_admins' %>
    <div>
      <%= form.label :shop_id, "Assigned Shop", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.collection_select :shop_id, current_mall_admin.mall.shops, :id, :name, { prompt: "Select a shop" }, class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-primary focus:border-primary" %>
    </div>
  <% end %>

  <%# Shop image upload — only show to shop admins editing their own profile %>
  <% if current_shop_admin && shop_admin.persisted? && shop_admin.shop.present? %>
    <div class="border border-gray-200 rounded-xl p-5 bg-gray-50/50">
      <h3 class="text-sm font-semibold text-gray-800 mb-4 flex items-center gap-2">
        <svg class="w-4 h-4 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        Shop Images
      </h3>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <%# Logo %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Shop Logo</label>
          <% if shop_admin.shop.logo_url.present? %>
            <div class="mb-3">
              <img src="<%= shop_admin.shop.logo_url %>" alt="Current logo" class="w-20 h-20 rounded-xl object-cover border border-gray-200 shadow-sm">
              <p class="text-xs text-gray-400 mt-1">Current logo</p>
            </div>
          <% end %>
          <div class="flex items-center gap-3">
            <label for="shop_admin_logo_file" class="inline-flex items-center gap-2 px-4 py-2.5 bg-white hover:bg-gray-100 text-gray-700 text-sm font-medium rounded-lg cursor-pointer transition-colors border border-gray-300">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              Choose Logo
            </label>
            <span id="sa_logo_file_name" class="text-sm text-gray-400">No file chosen</span>
          </div>
          <%= form.file_field :logo_file, accept: "image/*", class: "hidden", id: "shop_admin_logo_file", onchange: "document.getElementById('sa_logo_file_name').textContent = this.files[0] ? this.files[0].name : 'No file chosen'" %>
        </div>

        <%# Cover Image %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Cover Image</label>
          <% if shop_admin.shop.cover_image_url.present? %>
            <div class="mb-3">
              <img src="<%= shop_admin.shop.cover_image_url %>" alt="Current cover" class="w-full h-20 rounded-xl object-cover border border-gray-200 shadow-sm">
              <p class="text-xs text-gray-400 mt-1">Current cover</p>
            </div>
          <% end %>
          <div class="flex items-center gap-3">
            <label for="shop_admin_cover_file" class="inline-flex items-center gap-2 px-4 py-2.5 bg-white hover:bg-gray-100 text-gray-700 text-sm font-medium rounded-lg cursor-pointer transition-colors border border-gray-300">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              Choose Cover
            </label>
            <span id="sa_cover_file_name" class="text-sm text-gray-400">No file chosen</span>
          </div>
          <%= form.file_field :cover_image_file, accept: "image/*", class: "hidden", id: "shop_admin_cover_file", onchange: "document.getElementById('sa_cover_file_name').textContent = this.files[0] ? this.files[0].name : 'No file chosen'" %>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4 border-t border-gray-100">
    <div>
      <%= form.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.password_field :password, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-primary focus:ring-primary sm:text-sm", placeholder: shop_admin.persisted? ? "Leave blank to keep same" : "Required" %>
    </div>

    <div>
      <%= form.label :password_confirmation, "Confirm Password", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.password_field :password_confirmation, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-primary focus:ring-primary sm:text-sm" %>
    </div>
  </div>

  <div class="flex items-center justify-end gap-3 pt-6 border-t border-gray-100">
    <%= link_to "Cancel", 'javascript:history.back()', class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors" %>
    <%= form.submit shop_admin.persisted? ? "Update Profile" : "Create Admin", class: "px-4 py-2 text-sm font-medium text-white bg-primary border border-transparent rounded-lg hover:bg-primary-light transition-colors cursor-pointer" %>
  </div>
<% end %>
