<% content_for(:page_title) { @mall.name } %>

<div class="mb-6">
  <%= link_to malls_path, class: "inline-flex items-center gap-1 text-sm text-secondary hover:text-primary transition-colors" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Back to Malls
  <% end %>
</div>

<div class="bg-white rounded-xl border border-gray-100 overflow-hidden">
  <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
    <h2 class="text-xl font-bold text-primary"><%= @mall.name %></h2>
    <div class="flex gap-2">
      <%= link_to edit_mall_path(@mall), class: "inline-flex items-center gap-2 px-3 py-2 bg-warning/10 text-warning hover:bg-warning/20 text-sm font-medium rounded-lg transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        Edit
      <% end %>
    </div>
  </div>

  <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Mall Name</p>
      <p class="text-sm text-primary font-medium"><%= @mall.name %></p>
    </div>
    <div>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Location</p>
      <p class="text-sm text-gray-700"><%= @mall.location || "—" %></p>
    </div>
    <div>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Logo URL</p>
      <p class="text-sm text-gray-700 truncate"><%= @mall.logo_url || "—" %></p>
    </div>
    <div>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Cover Image URL</p>
      <p class="text-sm text-gray-700 truncate"><%= @mall.cover_image_url || "—" %></p>
    </div>
    <div>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Created At</p>
      <p class="text-sm text-gray-700"><%= @mall.created_at.strftime("%B %d, %Y at %H:%M") %></p>
    </div>
    <div>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Total Shops</p>
      <p class="text-sm text-gray-700"><%= @mall.shops.count %></p>
    </div>
  </div>
</div>
