<%= form_with(model: mall) do |form| %>
  <% if mall.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(mall.errors.count, "error") %> prohibited this mall from being saved:</h2>

      <ul>
        <% mall.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :mall_name, style: "display: block" %>
    <%= form.text_field :mall_name %>
  </div>

  <div>
    <%= form.label :location, style: "display: block" %>
    <%= form.text_field :location %>
  </div>

  <div>
    <%= form.label :logo_url, style: "display: block" %>
    <%= form.text_field :logo_url %>
  </div>

  <div>
    <%= form.label :cover_image_url, style: "display: block" %>
