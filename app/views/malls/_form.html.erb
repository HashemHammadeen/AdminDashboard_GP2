<%= form_with(model: mall, class: "space-y-5") do |form| %>
  <% if mall.errors.any? %>
    <div class="bg-error/10 border border-error/20 rounded-lg p-4">
      <h3 class="text-sm font-semibold text-error mb-2"><%= pluralize(mall.errors.count, "error") %> prohibited this mall from being saved:</h3>
      <ul class="list-disc list-inside text-sm text-error/80 space-y-1">
        <% mall.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, "Mall Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :name, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors", placeholder: "Enter mall name" %>
  </div>

  <div>
    <%= form.label :location, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :location, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors", placeholder: "Enter location" %>
  </div>

  <div>
    <%= form.label :logo_url, "Logo URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :logo_url, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors", placeholder: "https://..." %>
  </div>

  <div>
    <%= form.label :cover_image_url, "Cover Image URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :cover_image_url, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors", placeholder: "https://..." %>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= form.submit class: "px-5 py-2.5 bg-primary hover:bg-primary-light text-white text-sm font-medium rounded-lg transition-colors cursor-pointer" %>
    <%= link_to "Cancel", malls_path, class: "px-5 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg transition-colors" %>
  </div>
<% end %>
