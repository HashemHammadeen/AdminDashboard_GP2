<% content_for(:page_title) { "Audit Log" } %>
<div class="mb-6">
  <h1 class="text-2xl font-bold text-primary">Audit Log</h1>
  <p class="text-sm text-gray-500 mt-1">System-wide activity tracking</p>
</div>

<div class="bg-white rounded-xl border border-gray-100 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr class="bg-gray-50 border-b border-gray-100">
          <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Action</th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Admin Type</th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Points</th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Date</th>
          <th class="text-center text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @audit_logs.each_with_index do |log, idx| %>
          <tr class="<%= idx.even? ? 'bg-white' : 'bg-quaternary/30' %> hover:bg-ternary/10 transition-colors">
            <td class="px-6 py-4">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-secondary/10 text-secondary capitalize"><%= log.action_type&.titleize || "Unknown" %></span>
              <div class="text-xs text-gray-400 mt-1"><%= log.metadata&.dig('model_name') || "Unknown Record" %> | <%= log.metadata&.dig('record_id').to_s.first(8) %></div>
            </td>
            <td class="px-6 py-4">
              <% admin_id = log.mall_admin_id || log.shop_admin_id %>
              <% admin_type = log.mall_admin_id ? "Mall Admin" : (log.shop_admin_id ? "Shop Admin" : nil) %>
              <span class="text-sm font-medium text-primary block"><%= admin_type || "System" %></span>
              <span class="text-xs text-gray-500 font-mono"><%= admin_id.to_s.first(8) %></span>
            </td>
            <td class="px-6 py-4 text-sm font-medium">
              <% if log.points && log.points > 0 %>
                <span class="text-success"><%= "+#{log.points}" %></span>
              <% elsif log.points && log.points < 0 %>
                <span class="text-error"><%= log.points %></span>
              <% else %>
                <span class="text-gray-400">—</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= log.created_at.strftime("%b %d, %Y %H:%M:%S") %></td>
            <td class="px-6 py-4 text-center">
              <%= link_to audit_log_path(log), class: "inline-flex items-center justify-center p-2 rounded-lg text-gray-400 hover:text-secondary hover:bg-secondary/10 transition-colors" do %>
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @audit_logs.empty? %>
          <tr><td colspan="5" class="px-6 py-12 text-center text-gray-400 text-sm">No audit logs found</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
