<% content_for(:page_title) { "Audit Log" } %>
<div class="mb-6">
  <h1 class="text-2xl font-bold text-primary">Audit Log</h1>
  <p class="text-sm text-gray-500 mt-1">System-wide activity tracking</p>
</div>

<div class="bg-white rounded-xl border border-gray-100 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr class="bg-gray-50 border-b border-gray-100">
          <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Action</th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Admin Type</th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Points</th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Date</th>
          <th class="text-right text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @audit_logs.each_with_index do |log, idx| %>
          <tr class="<%= idx.even? ? 'bg-white' : 'bg-quaternary/30' %> hover:bg-ternary/10 transition-colors">
            <td class="px-6 py-4">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-secondary/10 text-secondary"><%= log.action_type %></span>
            </td>
            <td class="px-6 py-4 text-sm text-gray-600"><%= log.admin_type || "—" %></td>
            <td class="px-6 py-4 text-sm font-medium text-primary"><%= log.points || "—" %></td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= log.created_at.strftime("%b %d, %Y %H:%M") %></td>
            <td class="px-6 py-4 text-right">
              <%= link_to audit_log_path(log), class: "p-1.5 rounded-lg text-gray-400 hover:text-secondary hover:bg-secondary/10 transition-colors" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @audit_logs.empty? %>
          <tr><td colspan="5" class="px-6 py-12 text-center text-gray-400 text-sm">No audit logs found</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
