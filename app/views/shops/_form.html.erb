<%= form_with(model: shop) do |form| %>
  <% if shop.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(shop.errors.count, "error") %> prohibited this shop from being saved:</h2>

      <ul>
        <% shop.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :mall_id, style: "display: block" %>
    <%= form.text_field :mall_id %>
  </div>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :category_id, style: "display: block" %>
    <%= form.text_field :category_id %>
  </div>

  <div>
    <%= form.label :logo_url, style: "display: block" %>
    <%= form.text_field :logo_url %>
  </div>

  <div>
    <%= form.label :cover_image_url, style: "display: block" %>
    <%= form.text_field :cover_image_url %>
  </div>

  <div>
    <%= form.label :bio, style: "display: block" %>
    <%= form.textarea :bio %>
  </div>

  <div>
    <%= form.label :website_url, style: "display: block" %>
    <%= form.text_field :website_url %>
  </div>

  <div>
    <%= form.label :social_links, style: "display: block" %>
    <%= form.text_field :social_links %>
  </div>

  <div>
    <%= form.label :is_active, style: "display: block" %>
    <%= form.checkbox :is_active %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
