<%= form_with(model: shop, class: "space-y-5") do |form| %>
  <% if shop.errors.any? %>
    <div class="bg-error/10 border border-error/20 rounded-lg p-4">
      <h3 class="text-sm font-semibold text-error mb-2"><%= pluralize(shop.errors.count, "error") %> prohibited this shop from being saved:</h3>
      <ul class="list-disc list-inside text-sm text-error/80 space-y-1">
        <% shop.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    <div>
      <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :name, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors", placeholder: "Shop name" %>
    </div>

    <% unless current_mall %>
      <div>
        <%= form.label :mall_id, "Mall", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.collection_select :mall_id, Mall.all, :id, :mall_name, { prompt: "Select a mall" }, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors" %>
      </div>
    <% end %>

    <div>
      <%= form.label :category_id, "Category", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.collection_select :category_id, Category.all, :id, :name, { prompt: "Select a category" }, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors" %>
    </div>

    <div>
      <%= form.label :website_url, "Website URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.url_field :website_url, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors", placeholder: "https://..." %>
    </div>
  </div>

  <div>
    <%= form.label :bio, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_area :bio, rows: 3, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors resize-none", placeholder: "Shop description" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    <div>
      <%= form.label :logo_url, "Logo URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :logo_url, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors", placeholder: "https://..." %>
    </div>

    <div>
      <%= form.label :cover_image_url, "Cover Image URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :cover_image_url, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors", placeholder: "https://..." %>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <%= form.label :is_active, class: "flex items-center gap-2 cursor-pointer" do %>
      <%= form.check_box :is_active, class: "w-4 h-4 rounded border-gray-300 text-secondary focus:ring-secondary" %>
      <span class="text-sm font-medium text-gray-700">Active</span>
    <% end %>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= form.submit class: "px-5 py-2.5 bg-primary hover:bg-primary-light text-white text-sm font-medium rounded-lg transition-colors cursor-pointer" %>
    <%= link_to "Cancel", shops_path, class: "px-5 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg transition-colors" %>
  </div>
<% end %>
