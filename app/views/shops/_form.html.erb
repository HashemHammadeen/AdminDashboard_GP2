<%= form_with(model: shop, class: "space-y-5", multipart: true) do |form| %>
  <% if shop.errors.any? %>
    <div class="bg-error/10 border border-error/20 rounded-lg p-4">
      <h3 class="text-sm font-semibold text-error mb-2"><%= pluralize(shop.errors.count, "error") %> prohibited this shop from being saved:</h3>
      <ul class="list-disc list-inside text-sm text-error/80 space-y-1">
        <% shop.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    <div>
      <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :name, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors", placeholder: "Shop name" %>
    </div>

    <% unless current_mall %>
      <div>
        <%= form.label :mall_id, "Mall", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.collection_select :mall_id, Mall.all, :id, :name, { prompt: "Select a mall" }, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors" %>
      </div>
    <% end %>

    <div>
      <%= form.label :category_id, "Category", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.collection_select :category_id, Category.all, :id, :name, { prompt: "Select a category" }, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors" %>
    </div>

    <div>
      <%= form.label :website_url, "Website URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.url_field :website_url, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors", placeholder: "https://..." %>
    </div>
  </div>

  <div>
    <%= form.label :bio, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_area :bio, rows: 3, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors resize-none", placeholder: "Shop description" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Shop Logo</label>
      <% if shop.logo_url.present? %>
        <div class="mb-3">
          <img src="<%= shop.logo_url %>" alt="Current logo" class="w-20 h-20 rounded-lg object-cover border border-gray-200">
          <p class="text-xs text-gray-400 mt-1">Current logo</p>
        </div>
      <% end %>
      <div class="flex items-center gap-3">
        <label for="shop_logo_file" class="inline-flex items-center gap-2 px-4 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg cursor-pointer transition-colors border border-gray-200">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          Choose Logo
        </label>
        <span id="logo_file_name" class="text-sm text-gray-500">No file chosen</span>
      </div>
      <%= form.file_field :logo_file, accept: "image/*", class: "hidden", id: "shop_logo_file", onchange: "document.getElementById('logo_file_name').textContent = this.files[0] ? this.files[0].name : 'No file chosen'" %>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Cover Image</label>
      <% if shop.cover_image_url.present? %>
        <div class="mb-3">
          <img src="<%= shop.cover_image_url %>" alt="Current cover" class="w-full h-20 rounded-lg object-cover border border-gray-200">
          <p class="text-xs text-gray-400 mt-1">Current cover image</p>
        </div>
      <% end %>
      <div class="flex items-center gap-3">
        <label for="shop_cover_image_file" class="inline-flex items-center gap-2 px-4 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg cursor-pointer transition-colors border border-gray-200">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          Choose Cover
        </label>
        <span id="cover_file_name" class="text-sm text-gray-500">No file chosen</span>
      </div>
      <%= form.file_field :cover_image_file, accept: "image/*", class: "hidden", id: "shop_cover_image_file", onchange: "document.getElementById('cover_file_name').textContent = this.files[0] ? this.files[0].name : 'No file chosen'" %>
    </div>
  </div>

  <div class="border-t border-gray-100 pt-5 mt-5">
    <h3 class="text-sm font-medium text-gray-900 mb-4">Social Media Links</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-5">
      <div>
        <%= form.label :facebook, "Facebook", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :facebook, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors", placeholder: "https://facebook.com/..." %>
      </div>

      <div>
        <%= form.label :instagram, "Instagram", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :instagram, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors", placeholder: "@username or https://..." %>
      </div>

      <div>
        <%= form.label :x, "X (Twitter)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :x, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors", placeholder: "https://x.com/..." %>
      </div>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <%= form.label :is_active, class: "flex items-center gap-2 cursor-pointer" do %>
      <%= form.check_box :is_active, class: "w-4 h-4 rounded border-gray-300 text-secondary focus:ring-secondary" %>
      <span class="text-sm font-medium text-gray-700">Active</span>
    <% end %>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= form.submit class: "px-5 py-2.5 bg-primary hover:bg-primary-light text-white text-sm font-medium rounded-lg transition-colors cursor-pointer" %>
    <%= link_to "Cancel", shops_path, class: "px-5 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg transition-colors" %>
  </div>
<% end %>
