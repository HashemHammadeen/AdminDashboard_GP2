<% content_for(:page_title) { "Edit System Config" } %>
<div class="mb-6"><%= link_to system_configs_path, class: "inline-flex items-center gap-1 text-sm text-secondary hover:text-primary transition-colors" do %><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>Back<% end %></div>
<div class="bg-white rounded-xl border border-gray-100 overflow-hidden max-w-2xl">
  <div class="px-6 py-5 border-b border-gray-100"><h2 class="text-xl font-bold text-primary">Edit System Configuration</h2></div>
  <div class="p-6">
    <%= form_with(model: @system_config, class: "space-y-5") do |form| %>
      <div>
        <%= form.label :earn_points_per_currency, "Earn Points per Currency Unit", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.number_field :earn_points_per_currency, step: 0.01, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors" %>
      </div>
      <div>
        <%= form.label :min_redemption_threshold, "Min Redemption Threshold (pts)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.number_field :min_redemption_threshold, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors" %>
      </div>
      <div>
        <%= form.label :points_to_currency_ratio, "Points to Currency Ratio", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.number_field :points_to_currency_ratio, step: 0.0001, class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-primary focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary transition-colors" %>
      </div>
      <div class="flex items-center gap-3 pt-2">
        <%= form.submit "Save Changes", class: "px-5 py-2.5 bg-primary hover:bg-primary-light text-white text-sm font-medium rounded-lg transition-colors cursor-pointer" %>
        <%= link_to "Cancel", system_configs_path, class: "px-5 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
