<%= form_with(model: system_config) do |form| %>
  <% if system_config.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(system_config.errors.count, "error") %> prohibited this system_config from being saved:</h2>

      <ul>
        <% system_config.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :points_to_currency_ratio, style: "display: block" %>
    <%= form.text_field :points_to_currency_ratio %>
  </div>

  <div>
    <%= form.label :earn_points_per_currency, style: "display: block" %>
    <%= form.text_field :earn_points_per_currency %>
  </div>

  <div>
    <%= form.label :min_redemption_threshold, style: "display: block" %>
    <%= form.number_field :min_redemption_threshold %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
