<% content_for(:page_title) { "System Configuration" } %>
<div class="mb-6">
  <h1 class="text-2xl font-bold text-primary">System Configuration</h1>
  <p class="text-sm text-gray-500 mt-1">Global loyalty program settings</p>
</div>

<div class="space-y-6">
  <% @system_configs.each do |config| %>
    <div class="bg-white rounded-xl border border-gray-100 overflow-hidden">
      <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
        <h3 class="text-lg font-semibold text-primary">Configuration #<%= config.id %></h3>
        <%= link_to edit_system_config_path(config), class: "inline-flex items-center gap-2 px-3 py-2 bg-warning/10 text-warning hover:bg-warning/20 text-sm font-medium rounded-lg transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          Edit
        <% end %>
      </div>
      <div class="p-6 grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div class="bg-gray-50 rounded-lg p-4">
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Earn Points per Currency</p>
          <p class="text-2xl font-bold text-primary mt-2"><%= config.earn_points_per_currency %></p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4">
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Min Redemption Threshold</p>
          <p class="text-2xl font-bold text-primary mt-2"><%= config.min_redemption_threshold %> <span class="text-sm text-gray-400">pts</span></p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4">
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Points to Currency Ratio</p>
          <p class="text-2xl font-bold text-primary mt-2"><%= config.points_to_currency_ratio %></p>
        </div>
      </div>
    </div>
  <% end %>
</div>
