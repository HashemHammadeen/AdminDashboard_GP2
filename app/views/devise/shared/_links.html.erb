<%# Shared links partial - styled for dark backgrounds %>
<div class="flex flex-col items-center gap-1 text-sm">
  <%- if controller_name != 'sessions' %>
    <%= link_to "Sign in", new_session_path(resource_name), class: "text-ternary/70 hover:text-white transition-colors" %><br />
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-ternary/70 hover:text-white transition-colors" %><br />
  <% end %>
</div>
