<% content_for(:page_title) { "Data Analysis" } %>

<div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
  <div>
    <h1 class="text-2xl font-bold text-primary">Data Analysis</h1>
    <p class="text-sm text-gray-500 mt-1">
      <% if current_mall_admin %>
        Mall Intelligence Dashboard — <%= current_mall.name %>
      <% else %>
        Shop Performance Metrics — <%= current_shop.name %>
      <% end %>
    </p>
  </div>
</div>

<%# MAIN CHARTS GRID %>
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
  
  <%# Points Velocity %>
  <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm lg:col-span-2">
    <div class="flex justify-between items-center mb-6">
      <h3 class="text-lg font-bold text-primary">Points Velocity <span class="text-xs font-normal text-gray-400 ml-2">Past 30 Days</span></h3>
    </div>
    <div class="w-full h-80">
      <%= line_chart @points_velocity_data, 
          colors: ["#547792", "#94B4C1"], 
          suffix: " pts", 
          curve: true,
          library: { scales: { y: { beginAtZero: true } } } %>
    </div>
  </div>

  <%# Active vs Inactive %>
  <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm flex flex-col">
    <div class="flex justify-between items-center mb-6">
      <h3 class="text-lg font-bold text-primary">User Engagement <span class="text-xs font-normal text-gray-400 ml-2">Past 7 Days</span></h3>
    </div>
    <div class="flex-1 min-h-[250px] flex items-center justify-center">
      <%= pie_chart @user_activity_data, donut: true, colors: ["#213448", "#f3f4f6"], legend: "bottom" %>
    </div>
  </div>

  <%# Daily Redemptions %>
  <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm lg:col-span-2">
    <div class="flex justify-between items-center mb-6">
      <h3 class="text-lg font-bold text-primary">Redemption Activity <span class="text-xs font-normal text-gray-400 ml-2">By Day of Week</span></h3>
    </div>
    <div class="w-full h-72">
      <%= column_chart @redemptions_by_day_of_week, 
          colors: ["#213448"], 
          library: { borderRadius: 4 } %>
    </div>
  </div>

  <%# Tier Distribution %>
  <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm flex flex-col">
    <div class="flex justify-between items-center mb-6">
      <h3 class="text-lg font-bold text-primary">Tier Distribution</h3>
    </div>
    <div class="flex-1 min-h-[250px] flex items-center justify-center">
      <%= pie_chart @tier_distribution, colors: ["#547792", "#94B4C1", "#ECEFCA", "#213448"], legend: "bottom" %>
    </div>
  </div>
</div>

<%# TOP CUSTOMERS TABLE %>
<div class="bg-white rounded-xl border border-gray-100 overflow-hidden shadow-sm">
  <div class="px-6 py-5 border-b border-gray-100 bg-gray-50/50">
    <h3 class="text-lg font-bold text-primary">Top Customers <span class="text-xs font-normal text-gray-400 ml-2">By <%= @top_customer_metric_name %></span></h3>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr class="bg-white border-b border-gray-100">
          <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-4">Customer</th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-4">Email</th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-4">Current Tier</th>
          <th class="text-right text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-4"><%= @top_customer_metric_name %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% if @top_customers.any? %>
          <% @top_customers.each_with_index do |user, idx| %>
            <tr class="bg-white hover:bg-ternary/5 transition-colors">
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-secondary/10 flex items-center justify-center text-secondary font-bold text-xs"><%= user.first_name[0] %><%= user.last_name[0] %></div>
                  <span class="text-sm font-medium text-primary"><%= user.first_name %> <%= user.last_name %></span>
                </div>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500"><%= user.email %></td>
              <td class="px-6 py-4">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium" style="background-color: <%= user.tier.color_hex %>20; color: <%= user.tier.color_hex %>;">
                  <%= user.tier.name %>
                </span>
              </td>
              <td class="px-6 py-4 text-sm font-bold text-secondary text-right"><%= number_with_delimiter(@top_customer_metric_method.call(user)) %> pts</td>
            </tr>
          <% end %>
        <% else %>
          <tr><td colspan="4" class="px-6 py-12 text-center text-gray-400 text-sm">No customer data available yet.</td></tr>
        <% end %>
      </tbody>
  </table>
  </div>
</div>

<%# ═══════════════════════════════════════════════════════════════
    SHOP PERFORMANCE ANALYTICS  (Mall Admin only)
════════════════════════════════════════════════════════════════ %>
<% if current_mall_admin %>

  <%# Section heading %>
  <div class="mt-10 mb-5 flex items-center gap-3">
    <div class="h-6 w-1 rounded-full bg-secondary"></div>
    <h2 class="text-xl font-bold text-primary">Shop Performance Analytics</h2>
    <span class="text-xs text-gray-400 font-normal mt-0.5">All-time data · <%= @shops.size %> shops</span>
  </div>

  <%# ── Row 1: Revenue · Volume · Points Efficiency ── %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">

    <%# Revenue by Shop %>
    <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm">
      <div class="mb-4">
        <h3 class="text-base font-bold text-primary">Revenue by Shop</h3>
        <p class="text-xs text-gray-400 mt-0.5">Total purchase amount (all time)</p>
      </div>
      <div class="w-full h-64">
        <%= bar_chart @revenue_by_shop,
            colors: ["#213448"],
            suffix: " JD",
            library: { borderRadius: 4, indexAxis: "y" } %>
      </div>
    </div>

    <%# Transaction Volume by Shop %>
    <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm">
      <div class="mb-4">
        <h3 class="text-base font-bold text-primary">Transaction Volume</h3>
        <p class="text-xs text-gray-400 mt-0.5">Earn transactions per shop</p>
      </div>
      <div class="w-full h-64">
        <%= bar_chart @volume_by_shop,
            colors: ["#547792"],
            library: { borderRadius: 4, indexAxis: "y" } %>
      </div>
    </div>

    <%# Points Efficiency by Shop %>
    <div class="bg-white rounded-xl border border-gray-100 p-6 shadow-sm">
      <div class="mb-4">
        <h3 class="text-base font-bold text-primary">Points Efficiency</h3>
        <p class="text-xs text-gray-400 mt-0.5">Issued vs redeemed per shop</p>
      </div>
      <div class="w-full h-64">
        <%= bar_chart @points_efficiency_data,
            colors: ["#547792", "#94B4C1"],
            suffix: " pts",
            library: { borderRadius: 4 } %>
      </div>
    </div>

  </div>

  <%# ── Row 2: Shop Performance Summary Table ── %>
  <div class="bg-white rounded-xl border border-gray-100 overflow-hidden shadow-sm mb-8">
    <div class="px-6 py-5 border-b border-gray-100 bg-gray-50/50 flex items-center justify-between">
      <h3 class="text-lg font-bold text-primary">
        Shop Performance Summary
        <span class="text-xs font-normal text-gray-400 ml-2">Sorted by revenue ↓</span>
      </h3>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-white border-b border-gray-100">
            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-4">Shop</th>
            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-4">Category</th>
            <th class="text-right text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-4">Revenue (JD)</th>
            <th class="text-right text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-4">Earn Txns</th>
            <th class="text-right text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-4">Pts Issued</th>
            <th class="text-right text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-4">Pts Redeemed</th>
            <th class="text-right text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-4">Redeem Txns</th>
            <th class="text-right text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-4">Receipts</th>
            <th class="text-center text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-4">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% if @shop_performance.any? %>
            <% @shop_performance.each do |row| %>
              <tr class="bg-white hover:bg-ternary/5 transition-colors">
                <td class="px-6 py-4 font-medium text-primary whitespace-nowrap">
                  <%= link_to row[:shop].name, shop_path(row[:shop]), class: "hover:text-secondary transition-colors" %>
                </td>
                <td class="px-6 py-4 text-gray-500 whitespace-nowrap"><%= row[:category] %></td>
                <td class="px-6 py-4 text-right font-semibold text-secondary"><%= number_with_delimiter(row[:revenue], delimiter: ",") %></td>
                <td class="px-6 py-4 text-right text-gray-600"><%= number_with_delimiter(row[:earn_count]) %></td>
                <td class="px-6 py-4 text-right text-gray-600"><%= number_with_delimiter(row[:points_issued]) %></td>
                <td class="px-6 py-4 text-right text-gray-600"><%= number_with_delimiter(row[:points_redeemed]) %></td>
                <td class="px-6 py-4 text-right text-gray-600"><%= number_with_delimiter(row[:redeem_count]) %></td>
                <td class="px-6 py-4 text-right text-gray-600"><%= number_with_delimiter(row[:receipt_count]) %></td>
                <td class="px-6 py-4 text-center">
                  <% if row[:active] %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800">
                      <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mr-1.5"></span>Active
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">
                      <span class="w-1.5 h-1.5 rounded-full bg-red-500 mr-1.5"></span>Inactive
                    </span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr><td colspan="9" class="px-6 py-12 text-center text-gray-400">No shop data available yet.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

<% end %>
