<% content_for(:page_title) { "Offer Redemptions" } %>
<% content_for(:page_subtitle) { "View offers redeemed by customers" } %>

<div class="mb-6 flex items-center justify-between">
  <div>
    <h3 class="text-lg font-medium text-primary">Redemptions History</h3>
  </div>
</div>

<div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm">
  <div class="overflow-x-auto">
    <table class="w-full text-left text-sm text-gray-600">
      <thead class="bg-gray-50 border-b border-gray-100 text-xs uppercase text-gray-500 font-semibold tracking-wider">
        <tr>
          <th class="px-6 py-4">Transaction ID</th>
          <th class="px-6 py-4">User</th>
          <th class="px-6 py-4">Offer Redeemed</th>
          <th class="px-6 py-4 text-right">Date</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% if @offer_redemptions.any? %>
          <% @offer_redemptions.each do |redemption| %>
            <tr class="hover:bg-gray-50/50 transition-colors group">
              <td class="px-6 py-4 font-mono text-xs text-secondary"><%= redemption.id.first(12) %></td>
              <td class="px-6 py-4 font-medium text-primary">
                <%= redemption.user ? [redemption.user.first_name, redemption.user.last_name].join(" ") : "Unknown User" %>
                <div class="text-xs text-gray-400 font-normal"><%= redemption.user&.email %></div>
              </td>
              <td class="px-6 py-4"><%= redemption.offer&.name || "—" %></td>
              <td class="px-6 py-4 text-right text-gray-400">
                <%= redemption.created_at.strftime("%b %d, %Y %H:%M") %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="5" class="px-6 py-12 text-center text-gray-500">
              <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <p class="text-base font-medium text-gray-900 mb-1">No redemptions found</p>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
