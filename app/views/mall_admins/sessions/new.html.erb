<% content_for(:title) { "Mall Admin Sign In" } %>

<div class="min-h-screen bg-gradient-to-br from-primary via-[#2a4460] to-secondary flex items-center justify-center p-4">
  <div class="w-full max-w-md">
    <!-- Back Link -->
    <div class="mb-6">
      <%= link_to root_path, class: "inline-flex items-center gap-1 text-ternary/80 hover:text-white text-sm transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to portal selector
      <% end %>
    </div>

    <!-- Card -->
    <div class="bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl overflow-hidden">
      <!-- Header -->
      <div class="px-8 pt-8 pb-6 text-center">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-xl bg-quaternary/20 mb-4">
          <svg class="w-7 h-7 text-quaternary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
        </div>
        <h1 class="text-2xl font-bold text-white mb-1">Mall Admin</h1>
        <p class="text-ternary text-sm">Sign in to your mall dashboard</p>
      </div>

      <!-- Form -->
      <div class="px-8 pb-8">
        <% if flash[:alert].present? %>
          <div class="mb-5 bg-error/20 border border-error/30 text-white rounded-xl px-4 py-3 text-sm">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-error flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
              <%= flash[:alert] %>
            </div>
          </div>
        <% end %>

        <%= form_with url: mall_admins_login_path, method: :post, class: "space-y-5" do |f| %>
          <div>
            <%= f.label :email, class: "block text-sm font-medium text-ternary mb-1.5" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "admin@example.com",
                class: "w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white text-sm placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-quaternary/50 focus:border-quaternary/50 transition-all" %>
          </div>

          <div>
            <%= f.label :password, class: "block text-sm font-medium text-ternary mb-1.5" %>
            <%= f.password_field :password, autocomplete: "current-password", placeholder: "••••••••",
                class: "w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white text-sm placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-quaternary/50 focus:border-quaternary/50 transition-all" %>
          </div>

          <div>
            <%= f.submit "Sign In", class: "w-full px-4 py-3.5 bg-quaternary hover:bg-quaternary/90 text-primary text-sm font-semibold rounded-xl transition-all cursor-pointer shadow-lg hover:shadow-xl hover:scale-[1.01] active:scale-[0.99]" %>
          </div>
        <% end %>
      </div>
    </div>

    <p class="text-center text-ternary/40 text-xs mt-6">&copy; <%= Date.current.year %> Mall Management System</p>
  </div>
</div>
